# ---------------------------------------------------------------------------
# Merlin — environment variables (example). Copy to `.env.local` and fill in.
# No secrets are committed. All values below are placeholders.
# ---------------------------------------------------------------------------

# Demonstration-request delivery endpoint (server-side).
# The /api/demo-request route forwards validated submissions here.
# Point it at your email service, CRM, HubSpot Forms endpoint, or scheduler
# webhook. If UNSET, the API runs in a documented development fallback that
# validates + logs the request server-side and never fakes email delivery.
DEMO_REQUEST_ENDPOINT=

# Optional bearer token sent as `Authorization: Bearer <token>` to the endpoint.
DEMO_REQUEST_API_KEY=

# Optional: URL or path to the explainer video (public). When set, the explainer
# component mounts a real <video> on play (no autoplay audio, lazy-loaded).
# Example: /assets/merlin-walkthrough.mp4  or  https://cdn.example.com/merlin.mp4
NEXT_PUBLIC_EXPLAINER_VIDEO_URL=
